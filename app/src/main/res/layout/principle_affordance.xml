<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Affordance"
        android:textSize="10sp"
        android:gravity="center"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <!-- Text input field (looks like you can type in it) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount"
        android:textSize="10sp"
        android:textColor="#000000"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/border_box"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="|"
            android:textSize="14sp"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- Tappable button (looks clickable) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/filled_box"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← looks tappable (filled)"
        android:textSize="9sp"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <!-- Disabled element (looks NOT clickable) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/border_box_dashed"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← looks disabled (dashed)"
        android:textSize="9sp"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <!-- Dropdown/selector (looks like it opens) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/border_box"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="11sp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v"
            android:textSize="12sp"
            android:textColor="#000000"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← looks like it opens"
        android:textSize="9sp"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <!-- Slider (looks draggable) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="@drawable/border_box"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← looks draggable"
        android:textSize="9sp"
        android:textColor="#000000"/>

</LinearLayout>