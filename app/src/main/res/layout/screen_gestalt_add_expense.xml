<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DDDDDD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/border_thick"
            android:padding="8dp">

            <!-- STATUS BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:text="9:41"
                    android:textSize="10sp"
                    android:textColor="#000000"
                    android:gravity="center_vertical"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="••• Wi-Fi  100%"
                    android:textSize="10sp"
                    android:textColor="#000000"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="‹"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:background="@drawable/border_rounded"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="New Expense"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#000000"/>
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- GROUP 1: Amount Details (Common Region via card) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/border_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT DETAILS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginBottom="10dp"/>

                    <!-- Proximity: label close to field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amount"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="2dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/border_rounded"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Currency"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="2dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/border_rounded"/>
                </LinearLayout>

                <!-- GROUP 2: Category (Common Region + Similarity) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/border_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATEGORY"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginBottom="10dp"/>

                    <!-- Similarity: all same shape & size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="4dp">
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/border_circle"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Food"
                                android:textSize="11sp"
                                android:textColor="#000000"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginHorizontal="4dp">
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/border_circle"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Transport"
                                android:textSize="11sp"
                                android:textColor="#000000"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginHorizontal="4dp">
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/border_circle"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Books"
                                android:textSize="11sp"
                                android:textColor="#000000"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginStart="4dp">
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/border_circle"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Other"
                                android:textSize="11sp"
                                android:textColor="#000000"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- GROUP 3: Additional Info (Common Region) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/border_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDITIONAL INFO"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="2dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/border_rounded"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Note"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="2dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/border_rounded"/>
                </LinearLayout>

                <!-- Save -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="SAVE EXPENSE"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/filled_rounded"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>