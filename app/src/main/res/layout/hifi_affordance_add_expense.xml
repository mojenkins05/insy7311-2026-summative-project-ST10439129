<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- STATUS BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="#1B5E20"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="9:41" android:textSize="11sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LTE  100%" android:textSize="11sp" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_top_bar"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✕"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:contentDescription="Close add expense screen"/>
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Add Expense"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#FFFFFF"/>
            <View android:layout_width="36dp" android:layout_height="36dp"/>
        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Amount input (AFFORDANCE: looks like a tappable field) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount (R)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="20dp"
                android:contentDescription="Amount input field, numbers only">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#757575"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="  0.00"
                    android:textSize="16sp"
                    android:textColor="#BDBDBD"/>
            </LinearLayout>

            <!-- Category dropdown (AFFORDANCE: arrow shows it's selectable) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="20dp"
                android:contentDescription="Category dropdown, tap to select a category">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Select a category"
                    android:textSize="14sp"
                    android:textColor="#BDBDBD"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="14sp"
                    android:textColor="#757575"/>
            </LinearLayout>

            <!-- Date picker (AFFORDANCE: calendar icon shows it opens a picker) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="20dp"
                android:contentDescription="Date picker, tap to choose a date">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="29 May 2026"
                    android:textSize="14sp"
                    android:textColor="#212121"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="18sp"/>
            </LinearLayout>

            <!-- Note field (AFFORDANCE: taller = multiline) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Note (Optional)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:paddingTop="12dp"
                android:layout_marginBottom="32dp"
                android:contentDescription="Optional note field">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add a note..."
                    android:textSize="14sp"
                    android:textColor="#BDBDBD"/>
            </LinearLayout>

            <!-- SAVE BUTTON (AFFORDANCE: raised, coloured = tappable) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Expense"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_primary_button"
                android:contentDescription="Save expense button"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>