<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- STATUS BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="#1B5E20"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="9:41"
                android:textSize="11sp"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LTE  100%"
                android:textSize="11sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_top_bar"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="PC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#2E7D32"
                android:background="@drawable/bg_circle_icon"
                android:contentDescription="PocketCampus logo"/>
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="  PocketCampus"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔔"
                android:textSize="16sp"
                android:gravity="center"
                android:contentDescription="Notifications button"/>
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="👤"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:contentDescription="Profile button"/>
        </LinearLayout>

        <!-- MAIN CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Greeting -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning, Thabo!"
                android:textSize="14sp"
                android:textColor="#757575"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Here's your budget overview"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <!-- BUDGET CARD (VISIBLE) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_primary_button"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="Remaining budget card showing R2450 remaining this month">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remaining This Month"
                    android:textSize="12sp"
                    android:textColor="#C8E6C9"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 2,450.00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <!-- Progress bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_bar_track"/>
                    <View
                        android:layout_width="180dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_bar_fill"
                        android:backgroundTint="#FFFFFF"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 1,550 of R 4,000 spent (39%)"
                    android:textSize="11sp"
                    android:textColor="#C8E6C9"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- QUICK ACTIONS (VISIBLE) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Add expense button">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#2E7D32"
                        android:background="@drawable/bg_circle_icon"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Expense"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="View deals button">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="%"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:textColor="#2E7D32"
                        android:background="@drawable/bg_circle_icon"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Deals"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:contentDescription="View reports button">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="📊"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_icon"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reports"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- RECENT EXPENSES (VISIBLE) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Recent Expenses"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All ›"
                    android:textSize="13sp"
                    android:textColor="#2E7D32"/>
            </LinearLayout>

            <!-- Expense item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:contentDescription="Expense item: Chicken sandwich, food category, R45">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🍔"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chicken Sandwich"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food · Today, 12:30 PM"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="- R 45.00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:contentDescription="Expense item: Bus fare, transport category, R20">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🚌"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus Fare to Campus"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transport · Today, 08:15 AM"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="- R 20.00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

        </LinearLayout>

        <!-- BOTTOM NAV -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_bottom_nav"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:contentDescription="Home tab, currently selected">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textStyle="bold" android:textColor="#2E7D32"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:contentDescription="Expenses tab">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expenses" android:textSize="10sp" android:textColor="#757575"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:contentDescription="Add expense button">
                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_primary_button"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:contentDescription="Deals tab">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏷" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deals" android:textSize="10sp" android:textColor="#757575"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:contentDescription="Reports tab">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reports" android:textSize="10sp" android:textColor="#757575"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>